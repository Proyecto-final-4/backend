#!/usr/bin/env sh

set -eu

commit_msg_file="$1"
commit_msg="$(sed -n '1p' "$commit_msg_file")"

allowed_prefixes='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'

if ! printf '%s' "$commit_msg" | grep -Eq "^(${allowed_prefixes})(\(.+\))?: .+"; then
  echo "ERROR: Invalid commit message format."
  echo "Use a prefix like: feat:, fix:, chore:, docs:, test:, refactor: ..."
  echo "Example: feat(auth): add JWT filter"
  exit 1
fi
